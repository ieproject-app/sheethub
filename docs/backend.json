
{
  "entities": {
    "BlogPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BlogPost",
      "type": "object",
      "description": "Represents a single blog post on the SnipBlog website.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "contentMdx": { "type": "string" },
        "excerpt": { "type": "string" },
        "heroImageUrl": { "type": "string" },
        "heroImageAltText": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" },
        "isPublished": { "type": "boolean" },
        "category": { "type": "string" }
      },
      "required": ["id", "title", "slug", "contentMdx", "publishDate", "isPublished"]
    },
    "QuickNote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuickNote",
      "type": "object",
      "description": "Represents a technical snippet or quick reference note.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "contentMdx": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean" }
      },
      "required": ["id", "title", "contentMdx", "date"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/blogPosts_published/{blogPostId}",
        "definition": {
          "entityName": "BlogPost"
        }
      },
      {
        "path": "/notes_published/{noteId}",
        "definition": {
          "entityName": "QuickNote"
        }
      }
    ]
  }
}
